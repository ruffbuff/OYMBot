# ============================================
# AI OFFICE PLATFORM - CONFIGURATION
# ============================================
# Скопируй этот файл: cp .env.example .env
# Или запусти: npm run onboard

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=4000
WS_PORT=4001

# Frontend URL (для CORS)
FRONTEND_URL=http://localhost:3000

# ============================================
# LLM PROVIDERS (выбери ОДИН)
# ============================================

# Option 1: OpenRouter (РЕКОМЕНДУЕТСЯ - есть бесплатный тариф!)
# Получи ключ: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-your-key-here
# LLM_PROVIDER=openrouter
# LLM_MODEL=openai/gpt-3.5-turbo

# Бесплатные модели на OpenRouter:
# - meta-llama/llama-3-8b-instruct:free
# - google/gemini-flash-1.5:free
# - mistralai/mistral-7b-instruct:free

# Option 2: OpenAI
# OPENAI_API_KEY=sk-proj-your-openai-key-here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-3.5-turbo

# Option 3: Ollama (локально, бесплатно)
# Установи: brew install ollama
# Запусти: ollama serve
# Скачай модель: ollama pull llama2
# OLLAMA_ENDPOINT=http://localhost:11434
# LLM_PROVIDER=ollama
# LLM_MODEL=llama2

# Option 4: Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-haiku-20240307

# ============================================
# AGENT CONFIGURATION
# ============================================
AGENTS_DIR=./agents
SKILLS_DIR=./skills

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info

# ============================================
# TELEGRAM BOT (будущая интеграция)
# ============================================
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# TELEGRAM_ENABLED=false
# TELEGRAM_ALLOWED_USERS=user1,user2,user3

# ============================================
# WHATSAPP (будущая интеграция)
# ============================================
# WHATSAPP_ENABLED=false
# WHATSAPP_API_KEY=your-whatsapp-api-key

# ============================================
# SECURITY (опционально)
# ============================================
# JWT_SECRET=your-random-jwt-secret-here
# API_KEY=your-api-key-for-external-access

# ============================================
# DATABASE (опционально - для будущего индексирования)
# ============================================
# DATABASE_URL=file:./backend/dev.db
