{
  "name": "oym-bot-backend",
  "version": "0.2.3",
  "type": "module",
  "description": "Backend server for AI Office Platform",
  "main": "dist/index.js",
  "scripts": {
    "onboard": "tsx src/cli/onboard.ts",
    "gateway": "tsx src/index.ts",
    "chat": "tsx src/cli/ChatBlessed.ts",
    "status": "tsx -e \"import {MemoryManager} from './src/services/memory/MemoryManager.js'; const mm = new MemoryManager('./agents'); mm.loadAllAgents().then(agents => console.log(agents.length > 0 ? '✅ Ready to start gateway' : '❌ Run npm run onboard first'))\"",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start:prod": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "ai",
    "agents",
    "office",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ruffbuff/OYMBot"
  },
  "bugs": {
    "url": "https://github.com/ruffbuff/OYMBot/issues"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "blessed": "^0.1.81",
    "chalk": "^5.3.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "helmet": "^7.1.0",
    "inquirer": "^9.2.12",
    "marked": "^11.1.1",
    "node-telegram-bot-api": "^0.64.0",
    "openai": "^4.26.0",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/blessed": "^0.1.25",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
